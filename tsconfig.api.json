{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist-api",
    "rootDir": "./api",
    "lib": ["ES2020"]
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "src", "dist"]
}
